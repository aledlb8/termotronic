---
import { footerLinks } from "../data/footer";
import Logos from "./logos.astro";
---

<footer
  class="relative mt-24 bg-gray-200 border-t border-gray-300 overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-gray-200/30 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-gray-200/20 rounded-full blur-3xl -z-10"></div>

  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-5 mb-12">
      {
        footerLinks.map((section) => (
          <div>
            <h3 class="text-lg font-bold mb-4 text-gray-900 border-b-2 border-brand-200 pb-2">
              {section.title}
            </h3>
            <ul class="space-y-3">
              {section.items?.map((link) =>
                link.open ? (
                  <li>
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-gray-600 hover:text-brand-600 transition-colors duration-300 flex items-center gap-2 group font-medium">
                      <span class="w-0 h-0.5 bg-brand-600 group-hover:w-4 transition-all duration-300"></span>
                      {link.title}
                    </a>
                  </li>
                ) : (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-gray-600 hover:text-brand-600 transition-colors duration-300 flex items-center gap-2 group font-medium">
                      <span class="w-0 h-0.5 bg-brand-600 group-hover:w-4 transition-all duration-300"></span>
                      {link.title}
                    </a>
                  </li>
                ),
              )}
            </ul>
          </div>
        ))
      }
      <div class="flex flex-col items-center sm:items-start lg:col-span-2">
        <a href="/" class="mb-6 transition-transform duration-300 hover:scale-105">
          <img src="/images/logoTermotronic.png" width={200} alt="Termotronic Logo" />
        </a>
        <Logos />
      </div>
    </div>

    <div class="border-t-2 border-gray-200 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-center md:text-left text-sm text-gray-600">
          Copyright © 1994 - {new Date().getFullYear()} Termotronic. Todos los derechos reservados.<br />
          <span class="text-gray-500 font-medium">RIF J-301781899</span>
        </p>
        <div class="flex flex-col items-center md:items-end gap-3">
          <p class="text-sm text-gray-600 text-center md:text-right font-medium">
            +58 (212) 239.6165 · (212) 237.4551 · (212) 237.5083
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
