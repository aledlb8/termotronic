---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
import Cta from "@components/cta.astro";
import Contact from "@components/contact.astro";
import { leerDistribuidores } from "../utils/distribuidores.js";

// Leer y organizar distribuidores
const distribuidoresPorEstado = leerDistribuidores();

// Ordenar estados alfabéticamente
const estadosOrdenados = Object.keys(distribuidoresPorEstado).sort();

// Función para extraer el primer número de teléfono
function obtenerPrimerTelefono(telefonos) {
  // Dividir por: coma, punto y coma, barra (con o sin espacios), o espacios
  const numeros = telefonos.split(/\s*[,;\/]\s*|\s+/);
  return numeros[0].trim();
}

// Función para obtener el resto de números (después del primero)
function obtenerRestoDeTelefonos(telefonos) {
  // Dividir por: coma, punto y coma, barra (con o sin espacios), o espacios
  const numeros = telefonos.split(/\s*[,;\/]\s*|\s+/);
  if (numeros.length > 1) {
    const resto = numeros.slice(1).map(n => n.trim()).filter(n => n).join(' / ');
    return ' / ' + resto;
  }
  return null;
}

// Función para generar URL de WhatsApp (solo con el primer número)
function generarWhatsAppUrl(telefono) {
  // Limpiar el número: quitar espacios, guiones, paréntesis, puntos
  let numeroLimpio = telefono.replace(/[\s\-()\.]/g, '');
  // Quitar el primer 0 si existe
  if (numeroLimpio.startsWith('0')) {
    numeroLimpio = numeroLimpio.substring(1);
  }
  return `https://wa.me/58${numeroLimpio}`;
}
---

<Layout
  title="Tiendas Termotronic y CBX"
  description="Nuestros distribuidores de Termotronic y CBX, ordenados por estados y ciudades">
  <Container>
    <Sectionhead>
      <Fragment slot="title">Distribuidores Autorizados</Fragment>
      <Fragment slot="desc">Encuentra tu distribuidor Termotronic y CBX más cercano</Fragment>
    </Sectionhead>

    <div class="mx-auto mt-12 max-w-5xl">
      <!-- Campo de búsqueda -->
      <div class="mb-8 sticky top-4 z-10 bg-white/95 backdrop-blur-sm rounded-xl shadow-lg p-4">
        <div class="relative">
          <Icon class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" name="mdi:magnify" />
          <input
            type="text"
            id="searchInput"
            placeholder="Buscar por estado, ciudad, dirección o nombre de tienda..."
            class="w-full pl-12 pr-4 py-3 border-2 border-gray-200 rounded-lg focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all"
          />
        </div>
        <div id="searchResults" class="mt-2 text-sm text-gray-600 hidden"></div>
        <div id="noResults" class="mt-4 p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-yellow-800 hidden">
          No se encontraron distribuidores que coincidan con tu búsqueda.
        </div>
      </div>

      <div id="distribuidoresList">
        {estadosOrdenados.map(estado => (
          <div class="estado-group mb-12" data-estado={estado.toLowerCase()}>
            <h2 class="text-3xl font-bold bg-gradient-to-r from-brand-700 to-brand-600 bg-clip-text text-transparent mb-6 border-b-2 border-brand-200 pb-2">
              {estado.toUpperCase()}
            </h2>

            {Object.keys(distribuidoresPorEstado[estado])
              .sort()
              .map(ciudad => (
                <div class="ciudad-group mb-8" data-ciudad={ciudad.toLowerCase()}>
                  {Object.keys(distribuidoresPorEstado[estado]).length > 1 && (
                    <h3 class="text-xl font-semibold text-gray-700 mb-4 ml-2">{ciudad}</h3>
                  )}

                  <div class="grid gap-4">
                    {distribuidoresPorEstado[estado][ciudad]
                      .sort((a, b) => a.nombre.localeCompare(b.nombre))
                      .map((distribuidor) => (
                      <div
                        class="distribuidor-item group p-6 border-l-4 border-brand-500 bg-white rounded-r-xl shadow-soft hover:shadow-medium transition-all duration-300 hover:-translate-x-1"
                        data-nombre={distribuidor.nombre.toLowerCase()}
                        data-direccion={distribuidor.direccion.toLowerCase()}
                        data-ciudad={distribuidor.ciudad.toLowerCase()}
                        data-estado={distribuidor.estado.toLowerCase()}
                      >
                      <div class="flex items-start gap-4">
                        <div class="flex-shrink-0 w-10 h-10 bg-gradient-to-br from-brand-500 to-brand-600 rounded-lg flex items-center justify-center">
                          <Icon class="w-6 h-6 text-white" name="mdi:store" />
                        </div>
                        <div class="flex-1 space-y-1">
                          <h4 class="text-lg font-bold text-gray-900 group-hover:text-brand-700 transition-colors">
                            {distribuidor.nombre}
                          </h4>
                          <p class="text-gray-600 flex items-center gap-2">
                            <Icon class="w-4 h-4 text-gray-400" name="mdi:map-marker" />
                            {distribuidor.direccion}
                          </p>
                          <p class="text-gray-500 text-sm">
                            {distribuidor.ciudad}, Edo. {distribuidor.estado}
                          </p>
                          <p class="text-brand-600 font-semibold flex items-center gap-2 flex-wrap">
                            <Icon class="w-4 h-4" name="mdi:phone" />
                            <span class="inline-flex items-center gap-1">
                              <span>{obtenerPrimerTelefono(distribuidor.telefonos)}</span>
                              <a
                                href={generarWhatsAppUrl(obtenerPrimerTelefono(distribuidor.telefonos))}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center hover:scale-110 transition-transform"
                                aria-label="Contactar por WhatsApp"
                              >
                                <svg class="w-[1.2em] h-[1.2em] text-green-600" viewBox="0 0 24 24" fill="currentColor">
                                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.821 11.821 0 0020.465 3.488"/>
                                </svg>
                              </a>
                            </span>
                            {obtenerRestoDeTelefonos(distribuidor.telefonos) && <span>{obtenerRestoDeTelefonos(distribuidor.telefonos)}</span>}
                          </p>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <div id="contact">
      <Contact />
    </div>
  </Container>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const noResults = document.getElementById('noResults');
    const distribuidoresList = document.getElementById('distribuidoresList');
    const estadoGroups = document.querySelectorAll('.estado-group');
    const ciudadGroups = document.querySelectorAll('.ciudad-group');
    const distribuidorItems = document.querySelectorAll('.distribuidor-item');

    function normalizeText(text) {
      return text
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '');
    }

    function filterDistribuidores() {
      const searchTerm = normalizeText(searchInput.value.trim());

      if (searchTerm === '') {
        // Mostrar todo
        estadoGroups.forEach(group => group.style.display = '');
        ciudadGroups.forEach(group => group.style.display = '');
        distribuidorItems.forEach(item => item.style.display = '');
        searchResults.classList.add('hidden');
        noResults.classList.add('hidden');
        return;
      }

      let visibleCount = 0;

      // Ocultar todo primero
      estadoGroups.forEach(group => group.style.display = 'none');
      ciudadGroups.forEach(group => group.style.display = 'none');
      distribuidorItems.forEach(item => item.style.display = 'none');

      // Filtrar distribuidores
      distribuidorItems.forEach(item => {
        const nombre = normalizeText(item.dataset.nombre || '');
        const direccion = normalizeText(item.dataset.direccion || '');
        const ciudad = normalizeText(item.dataset.ciudad || '');
        const estado = normalizeText(item.dataset.estado || '');

        const matches =
          nombre.includes(searchTerm) ||
          direccion.includes(searchTerm) ||
          ciudad.includes(searchTerm) ||
          estado.includes(searchTerm);

        if (matches) {
          item.style.display = '';
          visibleCount++;

          // Mostrar ciudad padre
          const ciudadGroup = item.closest('.ciudad-group');
          if (ciudadGroup) {
            ciudadGroup.style.display = '';

            // Mostrar estado padre
            const estadoGroup = ciudadGroup.closest('.estado-group');
            if (estadoGroup) {
              estadoGroup.style.display = '';
            }
          }
        }
      });

      // Mostrar resultados
      if (visibleCount > 0) {
        searchResults.textContent = `${visibleCount} distribuidor${visibleCount !== 1 ? 'es' : ''} encontrado${visibleCount !== 1 ? 's' : ''}`;
        searchResults.classList.remove('hidden');
        noResults.classList.add('hidden');
      } else {
        searchResults.classList.add('hidden');
        noResults.classList.remove('hidden');
      }
    }

    searchInput.addEventListener('input', filterDistribuidores);

    // Permitir limpiar la búsqueda con ESC
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        filterDistribuidores();
      }
    });
  });
</script>